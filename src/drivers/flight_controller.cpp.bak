#include "flight_controller.h"
#include <Arduino.h>
#include <math.h>

FlightController::FlightController(MotorDriver& motors)
    : _motors(motors)
    , _state(STATE_DISARMED)
    , _arm_btn_since(0), _arm_btn_was(false)
    , _last_packet_ms(0), _failsafe_throttle(0)
    , _bat_mv(0.0f), _bat_level(BAT_CRIT)
{}

void FlightController::init() {
    // Configure PIDs
    pid_pitch.init(PID_PITCH_P, PID_PITCH_I, PID_PITCH_D, -500.f, 500.f, PID_INTEGRAL_LIMIT);
    pid_roll .init(PID_ROLL_P,  PID_ROLL_I,  PID_ROLL_D,  -500.f, 500.f, PID_INTEGRAL_LIMIT);
    pid_yaw  .init(PID_YAW_P,   PID_YAW_I,   PID_YAW_D,   -500.f, 500.f, PID_INTEGRAL_LIMIT);

    _motors.stopAll();
    _last_packet_ms = millis();

    pinMode(BAT_ADC_PIN, INPUT_ANALOG);
    analogReadResolution(BAT_ADC_BITS);
    updateBattery();

    Serial.println(F("[FC] Flight controller initialised"));
    Serial.print  (F("[FC] State: DISARMED  BAT: "));
    Serial.print  (_bat_mv / 1000.0f, 2);
    Serial.println(F(" V"));
}

// ---------------------------------------------------------------------------
// Packet watchdog
// ---------------------------------------------------------------------------
void FlightController::packetReceived() {
    _last_packet_ms = millis();

    // Recover from failsafe if we get packets again
    if (_state == STATE_FAILSAFE || _state == STATE_LANDING) {
        // Do NOT automatically re-arm — require manual re-arm for safety
        Serial.println(F("[FC] Packets restored — remain DISARMED, re-arm required"));
        _state = STATE_DISARMED;
        _motors.stopAll();
    }
}

// ---------------------------------------------------------------------------
// Arm / Disarm button logic (call every loop)
// ---------------------------------------------------------------------------
void FlightController::updateArmButton(bool pressed) {
    uint32_t now = millis();

    // Detect leading edge
    if (pressed && !_arm_btn_was) {
        _arm_btn_since = now;
    }
    _arm_btn_was = pressed;

    if (!pressed) return;  // nothing to do while not pressed

    uint32_t held = now - _arm_btn_since;

    if (_state == STATE_DISARMED) {
        if (held >= ARM_HOLD_MS) {
            _state = STATE_ARMED;
            pid_pitch.reset();
            pid_roll .reset();
            pid_yaw  .reset();
            _failsafe_throttle = 0;
            beepArmed();
            Serial.println(F("[FC] *** ARMED ***"));
        }
    } else if (_state == STATE_ARMED) {
        if (held >= ARM_HOLD_MS) {
            _motors.stopAll();
            _state = STATE_DISARMED;
            pid_pitch.reset();
            pid_roll .reset();
            pid_yaw  .reset();
            beepDisarmed();
            Serial.println(F("[FC] *** DISARMED ***"));
        }
    }
}

// ---------------------------------------------------------------------------
// Main flight update (called at FLIGHT_LOOP_HZ)
// ---------------------------------------------------------------------------
void FlightController::update(float throttle_in, float pitch_in, float roll_in, float yaw_in,
                               float pitch_angle, float roll_angle, float yaw_rate_dps,
                               float dt)
{
    uint32_t now = millis();

    // ---- Failsafe check ----
    if (_state == STATE_ARMED) {
        if (now - _last_packet_ms > FAILSAFE_TIMEOUT_MS) {
            _state = STATE_FAILSAFE;
            _failsafe_throttle = (uint16_t)(throttle_in);
            beepFailsafe();
            Serial.println(F("[FC] *** FAILSAFE — packet timeout ***"));
        }
    }

    // ---- Battery critical → force disarm ----
    if (_bat_level == BAT_CRIT && _state == STATE_ARMED) {
        _motors.stopAll();
        _state = STATE_DISARMED;
        Serial.println(F("[FC] *** DISARMED — battery critical ***"));
        return;
    }

    // ---- State-based motor control ----
    switch (_state) {

    case STATE_DISARMED:
    case STATE_ARMING:
    case STATE_DISARMING:
        _motors.stopAll();
        return;

    case STATE_FAILSAFE:
    case STATE_LANDING: {
        // Controlled descent: reduce throttle by FAILSAFE_LAND_RATE per second
        float reduction = FAILSAFE_LAND_RATE * dt;
        if (_failsafe_throttle > reduction) {
            _failsafe_throttle -= (uint16_t)reduction;
        } else {
            _failsafe_throttle = 0;
        }

        if (_failsafe_throttle == 0) {
            _motors.stopAll();
            _state = STATE_DISARMED;
            Serial.println(F("[FC] Failsafe landing complete"));
            return;
        }
        // Fly level during descent (PIDs still active)
        mixAndApply((float)_failsafe_throttle,
                    pid_pitch.compute(0.0f, pitch_angle, dt),
                    pid_roll .compute(0.0f, roll_angle,  dt),
                    pid_yaw  .compute(0.0f, yaw_rate_dps, dt));
        return;
    }

    case STATE_ARMED: {
        // Map stick inputs to setpoints
        // throttle_in: 0-1000 → 0-MOTOR_SPEED_MAX after safety margin
        float throttle = fclamp(throttle_in, 0.f, (float)MOTOR_SPEED_MAX);

        // pitch_in / roll_in: -500..+500 → ±MAX_ANGLE_DEG setpoint
        float pitch_sp = (pitch_in / 500.0f) * MAX_ANGLE_DEG;
        float roll_sp  = (roll_in  / 500.0f) * MAX_ANGLE_DEG;
        // yaw_in: -500..+500 → ±MAX_YAW_RATE setpoint
        float yaw_sp   = (yaw_in   / 500.0f) * MAX_YAW_RATE;

        float pitch_out = pid_pitch.compute(pitch_sp, pitch_angle, dt);
        float roll_out  = pid_roll .compute(roll_sp,  roll_angle,  dt);
        float yaw_out   = pid_yaw  .compute(yaw_sp,   yaw_rate_dps, dt);

        // Minimum throttle guard: if stick is at zero, cut motors (not hover)
        if (throttle < MOTOR_IDLE_SPEED) {
            _motors.stopAll();
            pid_pitch.reset();
            pid_roll .reset();
            pid_yaw  .reset();
        } else {
            mixAndApply(throttle, pitch_out, roll_out, yaw_out);
        }
        return;
    }
    }
}

// ---------------------------------------------------------------------------
// X-config motor mixing
// ---------------------------------------------------------------------------
void FlightController::mixAndApply(float thr, float p, float r, float y) {
    // X-layout (view from top):
    //   FL(CCW) = T - Pitch + Roll + Yaw
    //   FR(CW)  = T - Pitch - Roll - Yaw
    //   RL(CW)  = T + Pitch + Roll - Yaw
    //   RR(CCW) = T + Pitch - Roll + Yaw
    float fl = thr - p + r + y;
    float fr = thr - p - r - y;
    float rl = thr + p + r - y;
    float rr = thr + p - r + y;

    // Clamp to valid range
    auto clampF = [](float v) -> uint16_t {
        if (v < 0.f)               return 0;
        if (v > MOTOR_SPEED_MAX)   return MOTOR_SPEED_MAX;
        return (uint16_t)v;
    };

    _motors.write(clampF(fl), clampF(fr), clampF(rl), clampF(rr));
}

// ---------------------------------------------------------------------------
// Battery
// ---------------------------------------------------------------------------
void FlightController::updateBattery() {
    // Read ADC and convert to millivolts
    uint16_t raw = (uint16_t)analogRead(BAT_ADC_PIN);
    float v_adc_mv = (float)raw * ((float)BAT_ADC_VREF_MV / (float)((1 << BAT_ADC_BITS) - 1));
    _bat_mv = v_adc_mv * BAT_DIVIDER_FACTOR;

    if      (_bat_mv >= BAT_MV_FULL)   _bat_level = BAT_FULL;
    else if (_bat_mv >= BAT_MV_MEDIUM) _bat_level = BAT_MEDIUM;
    else if (_bat_mv >= BAT_MV_LOW)    _bat_level = BAT_LOW;
    else                               _bat_level = BAT_CRIT;

    // Force-land on critical voltage
    if (_bat_level == BAT_CRIT && _state == STATE_ARMED) {
        _state = STATE_LANDING;
        _failsafe_throttle = MOTOR_SPEED_MAX / 2;
        Serial.print(F("[FC] CRITICAL battery: "));
        Serial.print(_bat_mv / 1000.0f, 2);
        Serial.println(F(" V — initiating emergency landing"));
    }
}

// ---------------------------------------------------------------------------
// Buzzer feedback
// ---------------------------------------------------------------------------
void FlightController::beepArmed() {
    // Two short rising beeps
    tone(BUZZER_PIN, 1500, 80); delay(100);
    tone(BUZZER_PIN, 2000, 80); delay(100);
    noTone(BUZZER_PIN);
}

void FlightController::beepDisarmed() {
    // Two short falling beeps
    tone(BUZZER_PIN, 2000, 80); delay(100);
    tone(BUZZER_PIN, 1000, 80); delay(100);
    noTone(BUZZER_PIN);
}

void FlightController::beepFailsafe() {
    // Three rapid beeps
    for (int i = 0; i < 3; i++) {
        tone(BUZZER_PIN, 3000, 60); delay(80);
        noTone(BUZZER_PIN); delay(40);
    }
}
